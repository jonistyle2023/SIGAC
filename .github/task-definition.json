{
  "family": "sigac-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::954096903879:role/ecsTaskExecutionRole",
  "taskRoleArn":      "arn:aws:iam::954096903879:role/sigacTaskRole",
  "containerDefinitions": [
    {
      "name": "sigac-backend",
      "image": "954096903879.dkr.ecr.us-east-1.amazonaws.com/sigac-backend:latest",
      "portMappings": [
        { "containerPort": 8080, "protocol": "tcp" }
      ],
      "essential": true,
      "environment": [
        { "name": "SPRING_PROFILES_ACTIVE", "value": "prod" },
        { "name": "AWS_REGION",             "value": "us-east-1" },
        { "name": "AWS_S3_BUCKET",          "value": "sigac-multimedia-prod" }
      ],
      "secrets": [
        { "name": "DB_URL",               "valueFrom": "/sigac/DB_URL" },
        { "name": "DB_USER",              "valueFrom": "/sigac/DB_USER" },
        { "name": "DB_PASS",              "valueFrom": "/sigac/DB_PASS" },
        { "name": "JWT_SECRET",           "valueFrom": "/sigac/JWT_SECRET" },
        { "name": "CORS_ALLOWED_ORIGINS", "valueFrom": "/sigac/CORS_ALLOWED_ORIGINS" },
        { "name": "BOOTSTRAP_SECRET",     "valueFrom": "/sigac/BOOTSTRAP_SECRET" },
        { "name": "GEMINI_API_KEY",       "valueFrom": "/sigac/GEMINI_API_KEY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/sigac-backend",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:8080/actuator/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
